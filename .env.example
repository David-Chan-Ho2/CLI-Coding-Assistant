# NEXUS Configuration File
# Copy this to .env and fill in your values

# ===== LLM Configuration =====

# Groq API Key (get from https://console.groq.com)
# Required for primary LLM provider
GROQ_API_KEY=your_groq_api_key_here

# Groq Model to use (default: mixtral-8x7b-32768)
GROQ_MODEL=mixtral-8x7b-32768

# Ollama Configuration (for local fallback)
# Base URL of Ollama server
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model to use (default: mistral, requires ollama pull mistral)
OLLAMA_MODEL=mistral

# ===== External Services =====

# Tavily API Key (get from https://tavily.com)
# Used for web search functionality
TAVILY_API_KEY=your_tavily_api_key_here

# ===== Execution Settings =====

# Execution mode: auto, manual, or confirmation
# - auto: Execute all tools without confirmation
# - manual: Require confirmation for all tools
# - confirmation: Only confirm high-risk operations
EXECUTION_MODE=auto

# Maximum iterations for agentic loop (prevents infinite loops)
MAX_ITERATIONS=10

# Maximum messages to send to LLM context window
MAX_CONTEXT_MESSAGES=20

# ===== Timeouts (in seconds) =====

# Timeout for LLM API calls
LLM_TIMEOUT=30.0

# Timeout for tool execution
TOOL_TIMEOUT=60.0

# Timeout for MCP server calls
MCP_TIMEOUT=10.0

# ===== Retry Configuration =====

# Maximum number of retries for transient errors
MAX_RETRIES=3

# Base backoff time in seconds (exponential: 1s, 2s, 4s, ...)
RETRY_BACKOFF_BASE=1.0

# ===== Directories =====

# Directory to save sessions
SESSION_DIR=./nexus_sessions

# Directory for RAG vector database
RAG_DB_DIR=./rag/chroma_db

# Directory for logs
LOG_DIR=./logs

# ===== Embedding Configuration =====

# Sentence transformer model for embeddings
# See https://huggingface.co/models?library=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Use local embeddings (true) or OpenAI API (false)
USE_LOCAL_EMBEDDINGS=true

# ===== Debug Settings =====

# Enable debug logging
DEBUG=false
